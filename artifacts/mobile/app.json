{
  "expo": {
    "name": "Zeno",
    "slug": "mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "mobile",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#7c3aed"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.boss.assistant",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSCameraUsageDescription": "Camera access is used to control the flashlight.",
        "NSMicrophoneUsageDescription": "Microphone access is used for voice input.",
        "NSContactsUsageDescription": "Contacts access is used to look up names when making calls or sending messages."
      }
    },
    "android": {
      "package": "com.boss.assistant",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.FLASHLIGHT",
        "android.permission.RECORD_AUDIO",
        "android.permission.READ_CONTACTS"
      ]
    },
    "web": {
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://replit.com/"
        }
      ],
      "expo-font",
      "expo-web-browser",
      [
        "expo-camera",
        {
          "cameraPermission": "Camera access is used to control the flashlight."
        }
      ],
      [
        "expo-av",
        {
          "microphonePermission": "Microphone access is used for voice input."
        }
      ],
      [
        "expo-contacts",
        {
          "contactsPermission": "Contacts access is used to look up names when making calls or sending messages."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "eas": {
        "projectId": "8eaf7ab7-7b70-4994-8781-016123ea23be"
      }
    }
  }
}
